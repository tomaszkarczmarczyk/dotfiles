alias refresh='source ~/.zshrc'

alias c=clear
alias history='omz_history -E'

alias eza='eza -lhgoATL 1 --time-style relative --group-directories-first --icons=always'
alias fd='fd --color=always'
alias stow='stow -v'

alias config-zsh='nvim ~/.zshrc'
alias config-aliases='nvim ~/.oh-my-zsh/custom/aliases.zsh'
alias config-nvim='nvim ~/.config/nvim/init.lua'

alias buuc='brew update && brew upgrade && brew cleanup'

alias icloud='z ~/Library/Mobile\ Documents/com~apple~CloudDocs'
alias obsidian='z ~/library/Mobile\ Documents/iCloud~md~obsidian/documents'
