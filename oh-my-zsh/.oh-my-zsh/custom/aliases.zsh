alias refresh='source ~/.zshrc'

alias c=clear

alias eza='eza -lhoATL 1 --time-style relative --group-directories-first --icons=always'
alias fd='fd --color=always'

alias config-zsh='nvim ~/.zshrc'
alias config-aliases='nvim ~/.oh-my-zsh/custom/aliases.zsh'
alias config-nvim='nvim ~/.config/nvim/init.lua'

alias history='omz_history -E'
